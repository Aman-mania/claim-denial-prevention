# Docker runtime. Uses OpenAI embeddings + sklearn vector index by default.
APP_ENV=docker
CLAIM_DENIAL_API_BASE_URL=http://api:8000
AUTH_DATABASE_URL=sqlite:///data/auth/auth.db
JWT_SECRET=local-docker-secret-change-me
JWT_EXPIRES_MINUTES=120

# RAG: Docker/AWS primary path. Requires OPENAI_API_KEY for policy ingestion and runtime retrieval.
RAG_EMBEDDING_BACKEND=openai
RAG_VECTOR_BACKEND=sklearn
RAG_ALLOW_EMBEDDING_FALLBACK=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BATCH_SIZE=64
OPENAI_EMBEDDING_TIMEOUT_SECONDS=30
OPENAI_API_KEY=replace_me_for_openai_rag

# Agent presentation layer. Keep false until API access is verified.
ENABLE_OPENAI_AGENT_OUTPUT=false
OPENAI_AGENT_MODEL=gpt-4o-mini
OPENAI_AGENT_TIMEOUT_SECONDS=20

GOLD_DIR=/app/data/gold
MODELS_DIR=/app/models
RAG_VECTOR_DIR=/app/data/vector_store
POLICY_RAW_DIR=/app/data/policies/raw
POLICY_PROCESSED_DIR=/app/data/policies/processed
