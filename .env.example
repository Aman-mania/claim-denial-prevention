# Claim Denial Prevention — local development environment example
# Copy this file to .env and edit values as needed.
# Do NOT commit .env.

# ── Week 6 RAG mode ───────────────────────────────────────────────────────────
# preferred = SentenceTransformers embeddings + FAISS vector index
# fallback  = TF-IDF embeddings + NumPy vector search
# auto      = let run_policy_ingest.py auto-select available backends
RAG_MODE=preferred

# Preferred local semantic embedding model.
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_EMBEDDING_BACKEND=sentence-transformers
RAG_VECTOR_BACKEND=faiss

# Retrieval controls. If you get too many unmatched reasons, lower min-score
# slightly after reviewing retrieval quality.
RAG_TOP_K=3
RAG_MIN_SCORE=0.20

# Policy document and vector-store paths.
RAG_POLICY_RAW_DIR=data/policies/raw
RAG_POLICY_PROCESSED_DIR=data/policies/processed
RAG_VECTOR_DIR=data/vector_store

# Chunking controls.
RAG_CHUNK_SIZE_WORDS=450
RAG_CHUNK_OVERLAP_WORDS=70

# Fallback embedding dimension. Used only for RAG_MODE=fallback or auto fallback.
RAG_HASHING_FEATURES=4096

# Recommended offline fallback for small local policy corpus.
RAG_FALLBACK_BACKEND=tfidf
RAG_TFIDF_MAX_FEATURES=8192

# In preferred mode, keep this false so dependency/download issues fail clearly
# instead of silently falling back to weaker retrieval.
RAG_ALLOW_PREFERRED_FALLBACK=false

# ── Hugging Face cache / timeout settings ─────────────────────────────────────
# HF_HOME controls local model cache. Keep it inside the project for portability.
HF_HOME=.cache/huggingface
HF_HUB_ETAG_TIMEOUT=60
HF_HUB_DOWNLOAD_TIMEOUT=120
HF_HUB_DISABLE_PROGRESS_BARS=1

# Set this only after the model has been cached locally.
# HF_HUB_OFFLINE=1
