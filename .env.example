# Claim Denial Prevention — local/AWS environment example
# Copy to .env and edit. Do NOT commit .env.

# ── Paths ─────────────────────────────────────────────────────────────────────
CLAIM_DENIAL_ROOT=.
GOLD_DIR=data/gold
MODELS_DIR=models

# ── Week 6 RAG mode ───────────────────────────────────────────────────────────
RAG_MODE=preferred
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_EMBEDDING_BACKEND=sentence-transformers
RAG_VECTOR_BACKEND=faiss
RAG_TOP_K=3
RAG_MIN_SCORE=0.20
RAG_POLICY_RAW_DIR=data/policies/raw
RAG_POLICY_PROCESSED_DIR=data/policies/processed
RAG_VECTOR_DIR=data/vector_store
RAG_CHUNK_SIZE_WORDS=200
RAG_CHUNK_OVERLAP_WORDS=50
RAG_HASHING_FEATURES=4096
RAG_FALLBACK_BACKEND=tfidf
RAG_TFIDF_MAX_FEATURES=8192
RAG_ALLOW_PREFERRED_FALLBACK=false

# Hugging Face cache / timeout settings
HF_HOME=.cache/huggingface
HF_HUB_ETAG_TIMEOUT=60
HF_HUB_DOWNLOAD_TIMEOUT=120
HF_HUB_DISABLE_PROGRESS_BARS=1
# HF_ENDPOINT=https://hf-mirror.com
# HF_HUB_OFFLINE=1

# ── Week 7 FastAPI/Auth ───────────────────────────────────────────────────────
# Local dev SQLite. AWS will use RDS PostgreSQL:
# AUTH_DATABASE_URL=postgresql://claim_app_user:password@rds-endpoint:5432/claim_denial
AUTH_DATABASE_URL=sqlite:///data/auth/auth.db
JWT_SECRET=change-this-before-aws-deployment
ACCESS_TOKEN_EXPIRE_MINUTES=120
API_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Seed users for scripts/init_auth_db.py
DEV_USER_EMAIL=developer@example.com
DEV_USER_PASSWORD=dev12345
ANALYST_USER_EMAIL=analyst@example.com
ANALYST_USER_PASSWORD=analyst12345

# ── Optional OpenAI presentation layer ────────────────────────────────────────
# OpenAI is only the final readable presentation layer. It does not calculate
# risk, retrieve policy, or override structured recommendations.
ENABLE_OPENAI_AGENT_OUTPUT=false
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-4o-mini
OPENAI_AGENT_TIMEOUT_SECONDS=20

# ── Phase 7: Role-aware Streamlit product UI ─────────────────────────────────
# FastAPI endpoint used by product_ui/app.py.
CLAIM_DENIAL_API_BASE_URL=http://localhost:8000
CLAIM_DENIAL_UI_API_TIMEOUT_SECONDS=45

# Developer dashboard is still available separately:
#   streamlit run dev_dashboard/app.py
# Product UI with login/role-based tabs:
#   streamlit run product_ui/app.py
