# Local Docker Compose execution. Copy to .env.docker before running docker compose.
APP_ENV=docker
CLAIM_DENIAL_ROOT=/app

AUTH_DATABASE_URL=sqlite:///data/auth/auth.db
JWT_SECRET=local-docker-secret-change-later
ACCESS_TOKEN_EXPIRE_MINUTES=120

CLAIM_DENIAL_API_BASE_URL=http://api:8000
CLAIM_DENIAL_UI_API_TIMEOUT_SECONDS=60
API_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,http://product-ui:8501

GOLD_DIR=data/gold
MODELS_DIR=models
RAG_VECTOR_DIR=data/vector_store
POLICIES_DIR=data/policies
LOGS_DIR=logs

ENABLE_OPENAI_AGENT_OUTPUT=false
OPENAI_AGENT_MODEL=gpt-4o-mini
# OPENAI_API_KEY=...

# Corporate-safe Docker defaults. This mode expects Week 6 vector artifacts to be
# built with TF-IDF fallback, not sentence-transformers.
RAG_MODE=fallback
RAG_EMBEDDING_BACKEND=tfidf
RAG_VECTOR_BACKEND=numpy
RAG_FALLBACK_BACKEND=tfidf
HF_HOME=/app/.cache/huggingface

# Leave false for fast/offline Docker builds. Set true only if you intentionally
# need sentence-transformers/faiss inside the API container.
INSTALL_SEMANTIC=false

AWS_REGION=us-east-1
USE_S3_ARTIFACTS=false
# S3_BUCKET_NAME=claim-denial-prevention-yourname
