# AWS/EC2 Docker runtime. Copy to .env.docker on EC2 and fill secrets safely.
APP_ENV=aws
CLAIM_DENIAL_API_BASE_URL=http://api:8000
AUTH_DATABASE_URL=postgresql://claim_user:<password>@<rds-endpoint>:5432/claim_denial
JWT_SECRET=<store-in-secrets-manager-or-secure-env>
JWT_EXPIRES_MINUTES=120

# Primary RAG path for AWS: OpenAI embeddings + sklearn vector index.
RAG_EMBEDDING_BACKEND=openai
RAG_VECTOR_BACKEND=sklearn
RAG_ALLOW_EMBEDDING_FALLBACK=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BATCH_SIZE=64
OPENAI_EMBEDDING_TIMEOUT_SECONDS=30
OPENAI_API_KEY=<store-in-secrets-manager-or-secure-env>

# Optional final text presentation layer.
ENABLE_OPENAI_AGENT_OUTPUT=true
OPENAI_AGENT_MODEL=gpt-4o-mini
OPENAI_AGENT_TIMEOUT_SECONDS=20

AWS_REGION=us-east-1
S3_BUCKET_NAME=<claim-denial-artifacts-bucket>
S3_ARTIFACT_PREFIX=claim-denial/prod

GOLD_DIR=/app/data/gold
MODELS_DIR=/app/models
RAG_VECTOR_DIR=/app/data/vector_store
POLICY_RAW_DIR=/app/data/policies/raw
POLICY_PROCESSED_DIR=/app/data/policies/processed
